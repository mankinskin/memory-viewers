.cargo/config.local.toml
.playwright-mcp/

# Local workspace data created by the CLI/REPL
.context-engine/
.audit/
.repo-qa/
packages/

# Spec/ticket store binary indexes (only the spec/ticket folders are tracked)
.spec/entities.redb
.spec/entities.db*
.spec/search_index/
.ticket/tickets.redb
.ticket/search_index/
