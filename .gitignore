target/
agents/tmp/
node_modules/

# Built frontend assets
tools/viewer/**/static/
tools/viewer/**/dist/
tools/context-editor/**/dist/
**/frontend/dioxus/dist/

# Generated Playwright output
**/playwright-report/
**/playwright-report-*/
**/test-results/
